def count_vowels(text):
    vowels = "aeiouAEIOU"
    count = sum(1 for char in text if char in vowels)
    return count

user_text = input("Введіть рядок для підрахунку голосних: ")
print("Кількість голосних:", count_vowels(user_text))
print()

def is_palindrome(text):
    cleaned = ''.join(char.lower() for char in text if char.isalnum())
    return cleaned == cleaned[::-1]

pal_text = input("Введіть рядок для перевірки на паліндром: ")
print("Паліндром?" , is_palindrome(pal_text))
print()

