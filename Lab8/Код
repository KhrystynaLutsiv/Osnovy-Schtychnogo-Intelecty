import tkinter as tk
from tkinter import ttk
import pandas as pd
from mlxtend.frequent_patterns import apriori, association_rules
import matplotlib.pyplot as plt


dataset = pd.DataFrame({
    'Milk': [1, 0, 1, 1, 0],
    'Bread': [1, 1, 0, 1, 0],
    'Butter': [0, 1, 1, 1, 0],
    'Beer': [1, 0, 1, 0, 1]
})



def run_apriori():
    try:
        min_sup = float(min_support_entry.get())
        min_conf = float(confidence_entry.get())
    except ValueError:
        result_text.set("Введіть коректні числа для порогів!")
        return

    frequent_itemsets = apriori(dataset, min_support=min_sup, use_colnames=True)

    rules = association_rules(frequent_itemsets, metric="lift", min_threshold=1)

    strong_rules = rules[rules['confidence'] >= min_conf]

    if strong_rules.empty:
        result_text.set("Правил не знайдено з такими параметрами.")
    else:
        output = ""
        for i, row in strong_rules.iterrows():
            output += f"{set(row['antecedents'])} => {set(row['consequents'])} | "
            output += f"Support: {row['support']:.2f}, Confidence: {row['confidence']:.2f}, Lift: {row['lift']:.2f}\n"
        result_text.set(output)

    plt.scatter(rules['support'], rules['confidence'], c=rules['lift'], cmap='viridis')
    plt.xlabel('Support')
    plt.ylabel('Confidence')
    plt.title('Association Rules')
    plt.colorbar(label='Lift')
    plt.show()


root = tk.Tk()
root.title("Лабораторна 8: Асоціативні правила")
root.geometry("600x500")

ttk.Label(root, text="Мінімальна підтримка (min_support)").pack(pady=5)
min_support_entry = ttk.Entry(root)
min_support_entry.insert(0, "0.6")
min_support_entry.pack(pady=5)

ttk.Label(root, text="Мінімальна достовірність (confidence)").pack(pady=5)
confidence_entry = ttk.Entry(root)
confidence_entry.insert(0, "0.7")
confidence_entry.pack(pady=5)

ttk.Button(root, text="Згенерувати правила", command=run_apriori).pack(pady=10)

result_text = tk.StringVar()
result_label = tk.Label(root, textvariable=result_text, justify='left', anchor='nw')
result_label.pack(fill='both', expand=True, padx=10, pady=10)

root.mainloop()
